# Where the config files for CTBRec are kept
CONFIG=./config
# Where CTBRec records to
MEDIA=./media

# Your TZ setting, only used inside Docker container
TZ=Australia/Sydney

# UID/GID that CTBRec will run under
PUID=1000
PGID=1000

# CTBRec server version baked into the image.
# Expected jar path in repo: rootfs/app/ctbrec-server-${CTBVER}-docker.jar
CTBVER=5.3.6-final